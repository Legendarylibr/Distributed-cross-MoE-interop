# Example environment for CEI Docker Compose

# --- addresses ---
CEI_REGISTRY_ADDR=registry:50051
CEI_ROUTER_ADDR=router:50052
CEI_LEARNER_ADDR=learner:50053
CEI_ADAPTER_HUB_ADDR=adapter-hub:50054
CEI_NODE_CODE=node-code:50061
CEI_NODE_MATH=node-math:50062
CEI_NODE_GENERAL=node-general:50063
CEI_PEER_ADDRS={"moe-code":"node-code:50061","moe-math":"node-math:50062","moe-general":"node-general:50063"}

# --- sim shape ---
CEI_CTX_DIM=33
CEI_DIM=32
CEI_SEED=0
CEI_STEPS=200
CEI_MODE=learned
CEI_LAYER_COMPAT=exact_layer

# --- security (match docker-compose x-cei-security for shared networks) ---
CEI_SECURITY_PROFILE=secure
CEI_AUTO_PROMOTE=1
CEI_OUTCOME_HMAC_SECRET=cei-compose-dev-secret
CEI_REQUIRE_OUTCOME_ATTESTATION=1
# HMAC request-auth token secret; rotate for real deployments.
CEI_AUTH_SECRET=cei-compose-dev-auth-secret
CEI_REQUIRE_AUTH_TOKEN=1
# CEI_AUTH_MAX_SKEW_MS=120000
# CEI_REQUIRE_ADAPTER_DIGEST=1
CEI_REGISTRY_ALLOW_ALL=0
CEI_REGISTRY_PUBLISHERS=node-code,node-math,node-general
CEI_REGISTRY_CONSUMERS=cei-router,host-code,host-math,host-general,node-code,node-math,node-general,cei-driver,e2e
CEI_NODE_ACL_OPEN=0
CEI_NODE_ACL_ALLOW=host-code,host-math,host-general,cei-driver,e2e
CEI_ADAPTER_WRITERS=node-code,node-math,node-general
# CEI_PRIORITY_ADMINS=
# CEI_REQUIRE_TLS=1
# CEI_TRUST_META_PRINCIPAL=0

# Optional TLS (after ./scripts/gen_dev_certs.sh deploy/certs)
# CEI_TLS_CERT=deploy/certs/server.crt
# CEI_TLS_KEY=deploy/certs/server.key
# CEI_TLS_CA=deploy/certs/ca.crt
# CEI_TLS_SERVER_NAME=cei.local

# Local laptop smoke (open ACLs — do not use on shared networks)
# CEI_SECURITY_PROFILE=lab
