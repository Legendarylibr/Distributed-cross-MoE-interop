# Example environment for CEI Docker Compose (dev profile: plaintext gRPC).
CEI_REGISTRY_ADDR=registry:50051
CEI_ROUTER_ADDR=router:50052
CEI_LEARNER_ADDR=learner:50053
CEI_NODE_CODE=node-code:50061
CEI_NODE_MATH=node-math:50062
CEI_NODE_GENERAL=node-general:50063
CEI_PEER_ADDRS={"moe-code":"node-code:50061","moe-math":"node-math:50062","moe-general":"node-general:50063"}
CEI_CTX_DIM=33
CEI_DIM=32
CEI_SEED=0
CEI_STEPS=200
CEI_MODE=learned

# Optional TLS (after ./scripts/gen_dev_certs.sh deploy/certs)
# CEI_TLS_CERT=deploy/certs/server.crt
# CEI_TLS_KEY=deploy/certs/server.key
# CEI_TLS_CA=deploy/certs/ca.crt
# CEI_TLS_SERVER_NAME=cei.local
