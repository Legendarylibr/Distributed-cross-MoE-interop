{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cei.spec/schemas/activation_batch.json",
  "title": "ActivationBatch",
  "type": "object",
  "required": ["shape", "dtype"],
  "properties": {
    "tensor_base64": {
      "type": "string",
      "description": "Inline tensor bytes (base64). Prefer buffer_ref for large payloads."
    },
    "buffer_ref": {
      "type": "string",
      "description": "RDMA or shared-memory handle (rdma profile)."
    },
    "shape": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 },
      "minItems": 1
    },
    "dtype": {
      "type": "string",
      "enum": ["F16", "BF16", "F32", "F8"]
    },
    "padding_mask_base64": { "type": "string" },
    "grad_required": { "type": "boolean" },
    "cache_key": { "type": "string" }
  },
  "anyOf": [
    { "required": ["tensor_base64"] },
    { "required": ["buffer_ref"] }
  ],
  "additionalProperties": false
}
